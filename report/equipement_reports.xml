<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Rapport 1 : Fiche individuelle d'équipement -->
    <record id="action_report_equipement_fiche" model="ir.actions.report">
        <field name="name">Fiche de l'équipement</field>
        <field name="model">it.equipement</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">it_parc.report_equipement_fiche_view</field>
        <field name="report_file">it_parc.report_equipement_fiche_view</field>
        <field name="print_report_name">'Fiche_' + (object.name or '').replace(' ', '_')</field>
        <field name="binding_model_id" ref="model_it_equipement"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Rapport 2 : Inventaire complet filtrable -->
    <record id="action_report_inventory_filtrable" model="ir.actions.report">
        <field name="name">Rapport d'inventaire</field>
        <field name="model">it.inventory.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">it_parc.report_inventory_filtrable_view</field>
        <field name="report_file">it_parc.report_inventory_filtrable_view</field>
        <field name="print_report_name">'Inventaire_Parc_Informatique'</field>
    </record>

    <!-- Rapport 3 : Historique des maintenances par période -->
    <record id="action_report_maintenance_period" model="ir.actions.report">
        <field name="name">Historique des maintenances</field>
        <field name="model">it.maintenance.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">it_parc.report_maintenance_period_view</field>
        <field name="report_file">it_parc.report_maintenance_period_view</field>
        <field name="print_report_name">'Rapport_Maintenances'</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================ -->
    <!-- RAPPORT 1 : Fiche individuelle d'un équipement               -->
    <!-- ============================================================ -->
    <template id="report_equipement_fiche_view">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <style>
                            .fiche-header { background: #1e3a5f; color: white; padding: 16px 20px; border-radius: 6px 6px 0 0; margin-bottom: 0; }
                            .fiche-header h2 { margin: 0; font-size: 20px; }
                            .fiche-header p { margin: 0; opacity: 0.8; }
                            .info-table { width: 100%; border-collapse: collapse; margin-top: 0; }
                            .info-table th { background: #f5f7fa; color: #555; font-weight: 600; text-align: left; padding: 8px 12px; border: 1px solid #dee2e6; width: 35%; }
                            .info-table td { padding: 8px 12px; border: 1px solid #dee2e6; }
                            .badge-assigned { background: #28a745; color: white; padding: 2px 10px; border-radius: 10px; font-size: 12px; }
                            .badge-maintenance { background: #ffc107; color: #333; padding: 2px 10px; border-radius: 10px; font-size: 12px; }
                            .badge-draft { background: #17a2b8; color: white; padding: 2px 10px; border-radius: 10px; font-size: 12px; }
                            .badge-retired { background: #6c757d; color: white; padding: 2px 10px; border-radius: 10px; font-size: 12px; }
                            .section-title { font-size: 14px; font-weight: 700; color: #1e3a5f; margin: 20px 0 8px 0; border-bottom: 2px solid #1e3a5f; padding-bottom: 4px; }
                            .interv-table { width: 100%; border-collapse: collapse; font-size: 12px; }
                            .interv-table th { background: #1e3a5f; color: white; padding: 6px 10px; text-align: left; }
                            .interv-table td { padding: 6px 10px; border: 1px solid #dee2e6; }
                            .interv-table tr:nth-child(even) td { background: #f9f9f9; }
                        </style>

                        <div class="fiche-header">
                            <h2>Fiche Équipement — <t t-esc="o.name"/></h2>
                            <p>Numéro de série : <t t-esc="o.serial_number"/></p>
                        </div>

                        <table class="info-table">
                            <tr>
                                <th>Catégorie</th>
                                <td><t t-esc="o.category_id.name or '—'"/></td>
                            </tr>
                            <tr>
                                <th>Localisation / Site</th>
                                <td><t t-esc="o.location_id.name or '—'"/></td>
                            </tr>
                            <tr>
                                <th>Employé affecté</th>
                                <td><t t-esc="o.employee_id.name or '—'"/></td>
                            </tr>
                            <tr>
                                <th>Département</th>
                                <td><t t-esc="o.department_id.name or '—'"/></td>
                            </tr>
                            <tr>
                                <th>Valeur d'achat</th>
                                <td><t t-esc="'{:,.0f}'.format(o.purchase_value)"/> FCFA</td>
                            </tr>
                            <tr>
                                <th>Date d'achat</th>
                                <td><t t-esc="o.purchase_date or '—'"/></td>
                            </tr>
                            <tr>
                                <th>Fin de garantie</th>
                                <td><t t-esc="o.warranty_date or '—'"/></td>
                            </tr>
                            <tr>
                                <th>État actuel</th>
                                <td>
                                    <t t-if="o.state == 'assigned'"><span class="badge-assigned">Affecté</span></t>
                                    <t t-elif="o.state == 'maintenance'"><span class="badge-maintenance">En maintenance</span></t>
                                    <t t-elif="o.state == 'draft'"><span class="badge-draft">Brouillon</span></t>
                                    <t t-elif="o.state == 'retired'"><span class="badge-retired">Retiré</span></t>
                                </td>
                            </tr>
                        </table>

                        <t t-if="o.description">
                            <div class="section-title">Description technique</div>
                            <p><t t-esc="o.description"/></p>
                        </t>

                        <t t-if="o.intervention_ids">
                            <div class="section-title">Historique des interventions</div>
                            <table class="interv-table">
                                <thead>
                                    <tr>
                                        <th>Référence</th>
                                        <th>Type</th>
                                        <th>Technicien</th>
                                        <th>Date début</th>
                                        <th>Durée (h)</th>
                                        <th>Coût (FCFA)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.intervention_ids" t-as="interv">
                                        <tr>
                                            <td><t t-esc="interv.name"/></td>
                                            <td><t t-esc="interv.type"/></td>
                                            <td><t t-esc="interv.technician_id.name"/></td>
                                            <td><t t-esc="interv.date_start"/></td>
                                            <td><t t-esc="'%.2f' % interv.duration"/></td>
                                            <td><t t-esc="'{:,.0f}'.format(interv.cost)"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- RAPPORT 2 : Inventaire complet filtrable                     -->
    <!-- ============================================================ -->
    <template id="report_inventory_filtrable_view">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <style>
                        .report-title { color: #1e3a5f; border-bottom: 3px solid #1e3a5f; padding-bottom: 6px; margin-bottom: 4px; }
                        .filters-info { background: #f5f7fa; border-left: 4px solid #1e3a5f; padding: 8px 12px; margin-bottom: 16px; font-size: 12px; color: #555; }
                        .inv-table { width: 100%; border-collapse: collapse; font-size: 11px; }
                        .inv-table th { background: #1e3a5f; color: white; padding: 6px 8px; text-align: left; }
                        .inv-table td { padding: 5px 8px; border: 1px solid #dee2e6; }
                        .inv-table tr:nth-child(even) td { background: #f5f7fa; }
                        .total-row td { font-weight: bold; background: #e8f0fe !important; }
                    </style>

                    <h2 class="report-title">Inventaire du Parc Informatique</h2>
                    <div class="filters-info">
                        Catégorie : <strong><t t-esc="data.get('category_name', 'Toutes')"/></strong> &#160;|&#160;
                        Département : <strong><t t-esc="data.get('department_name', 'Tous')"/></strong> &#160;|&#160;
                        Date d'édition : <strong><t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y')"/></strong>
                    </div>

                    <table class="inv-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Désignation</th>
                                <th>N° Série</th>
                                <th>Catégorie</th>
                                <th>Site</th>
                                <th>Employé</th>
                                <th>Département</th>
                                <th>Valeur (FCFA)</th>
                                <th>Fin Garantie</th>
                                <th>État</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="total_val" t-value="0"/>
                            <t t-foreach="docs" t-as="eq">
                                <t t-set="total_val" t-value="total_val + eq.purchase_value"/>
                                <tr>
                                    <td><t t-esc="eq_index + 1"/></td>
                                    <td><t t-esc="eq.name"/></td>
                                    <td><t t-esc="eq.serial_number"/></td>
                                    <td><t t-esc="eq.category_id.name or '—'"/></td>
                                    <td><t t-esc="eq.location_id.name or '—'"/></td>
                                    <td><t t-esc="eq.employee_id.name or '—'"/></td>
                                    <td><t t-esc="eq.department_id.name or '—'"/></td>
                                    <td><t t-esc="'{:,.0f}'.format(eq.purchase_value)"/></td>
                                    <td><t t-esc="eq.warranty_date or '—'"/></td>
                                    <td>
                                        <t t-if="eq.state == 'draft'">Brouillon</t>
                                        <t t-elif="eq.state == 'assigned'">Affecté</t>
                                        <t t-elif="eq.state == 'maintenance'">En maintenance</t>
                                        <t t-elif="eq.state == 'retired'">Retiré</t>
                                        <t t-else=""><t t-esc="eq.state"/></t>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                        <tfoot>
                            <tr class="total-row">
                                <td colspan="7" class="text-end">TOTAL VALEUR DU PARC :</td>
                                <td><t t-esc="'{:,.0f}'.format(total_val)"/> FCFA</td>
                                <td colspan="2"></td>
                            </tr>
                        </tfoot>
                    </table>
                    <p class="text-muted mt-4" style="font-size:10px;">
                        Nombre total d'équipements : <t t-esc="len(docs)"/>
                    </p>
                </div>
            </t>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- RAPPORT 3 : Historique des maintenances par période          -->
    <!-- ============================================================ -->
    <template id="report_maintenance_period_view">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <style>
                        .report-title { color: #1e3a5f; border-bottom: 3px solid #1e3a5f; padding-bottom: 6px; margin-bottom: 4px; }
                        .filters-info { background: #f5f7fa; border-left: 4px solid #1e3a5f; padding: 8px 12px; margin-bottom: 16px; font-size: 12px; color: #555; }
                        .maint-table { width: 100%; border-collapse: collapse; font-size: 11px; }
                        .maint-table th { background: #1e3a5f; color: white; padding: 6px 8px; text-align: left; }
                        .maint-table td { padding: 5px 8px; border: 1px solid #dee2e6; }
                        .maint-table tr:nth-child(even) td { background: #f5f7fa; }
                        .total-row td { font-weight: bold; background: #e8f0fe !important; }
                    </style>

                    <h2 class="report-title">Historique des Interventions de Maintenance</h2>
                    <div class="filters-info">
                        Période : Du <strong><t t-esc="data.get('date_start', '—')"/></strong> au <strong><t t-esc="data.get('date_end', '—')"/></strong>
                    </div>

                    <table class="maint-table">
                        <thead>
                            <tr>
                                <th>Référence</th>
                                <th>Équipement</th>
                                <th>Type</th>
                                <th>Technicien</th>
                                <th>Date début</th>
                                <th>Date fin</th>
                                <th>Durée (h)</th>
                                <th>Coût (FCFA)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="interv">
                                <tr>
                                    <td><t t-esc="interv.name"/></td>
                                    <td><t t-esc="interv.equipement_id.name"/></td>
                                    <td><t t-esc="interv.type"/></td>
                                    <td><t t-esc="interv.technician_id.name"/></td>
                                    <td><t t-esc="interv.date_start"/></td>
                                    <td><t t-esc="interv.date_end or '—'"/></td>
                                    <td><t t-esc="'%.2f' % interv.duration"/></td>
                                    <td><t t-esc="'{:,.0f}'.format(interv.cost)"/></td>
                                </tr>
                            </t>
                        </tbody>
                        <tfoot>
                            <tr class="total-row">
                                <td colspan="7" class="text-end">COÛT TOTAL DE MAINTENANCE :</td>
                                <td><t t-esc="'{:,.0f}'.format(data.get('total_cost', 0))"/> FCFA</td>
                            </tr>
                        </tfoot>
                    </table>
                    <p class="text-muted mt-4" style="font-size:10px;">
                        Nombre total d'interventions : <t t-esc="len(docs)"/>
                    </p>
                </div>
            </t>
        </t>
    </template>
</odoo>

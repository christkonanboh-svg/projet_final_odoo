<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_inherit_it_parc" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.it.parc</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button class="oe_stat_button"
                        name="action_open_it_equipements"
                        type="object"
                        icon="fa-laptop"
                        invisible="it_equipement_count == 0">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Équipement(s)</span>
                        <span class="o_stat_value"><field name="it_equipement_count"/></span>
                    </div>
                </button>
            </div>
        </field>
    </record>
</odoo>

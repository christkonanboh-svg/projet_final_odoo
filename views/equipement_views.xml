<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- CATEGORY VIEWS -->
    <record id="view_it_equipement_category_tree" model="ir.ui.view">
        <field name="name">it.equipement.category.tree</field>
        <field name="model">it.equipement.category</field>
        <field name="arch" type="xml">
            <list string="Catégories d'équipements">
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_it_equipement_category_form" model="ir.ui.view">
        <field name="name">it.equipement.category.form</field>
        <field name="model">it.equipement.category</field>
        <field name="arch" type="xml">
            <form string="Catégorie d'équipement">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Équipements dans cette catégorie" name="equipements">
                            <field name="equipement_ids" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_it_equipement_category" model="ir.actions.act_window">
        <field name="name">Catégories</field>
        <field name="res_model">it.equipement.category</field>
        <field name="view_mode">list,form</field>
    </record>


    <!-- LOCATION VIEWS -->
    <record id="view_it_location_tree" model="ir.ui.view">
        <field name="name">it.location.tree</field>
        <field name="model">it.location</field>
        <field name="arch" type="xml">
            <list string="Localisations / Sites">
                <field name="name"/>
                <field name="address"/>
            </list>
        </field>
    </record>

    <record id="view_it_location_form" model="ir.ui.view">
        <field name="name">it.location.form</field>
        <field name="model">it.location</field>
        <field name="arch" type="xml">
            <form string="Localisation / Site">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="address"/>
                    </group>
                    <notebook>
                        <page string="Équipements sur ce site" name="equipements">
                            <field name="equipement_ids" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_it_location" model="ir.actions.act_window">
        <field name="name">Localisations / Sites</field>
        <field name="res_model">it.location</field>
        <field name="view_mode">list,form</field>
    </record>


    <!-- EQUIPEMENT VIEWS -->
    <record id="view_it_equipement_tree" model="ir.ui.view">
        <field name="name">it.equipement.tree</field>
        <field name="model">it.equipement</field>
        <field name="arch" type="xml">
            <list string="Équipements" decoration-info="state == 'draft'" decoration-success="state == 'assigned'" decoration-warning="state == 'maintenance'" decoration-muted="state == 'retired'">
                <field name="name"/>
                <field name="serial_number"/>
                <field name="category_id"/>
                <field name="location_id"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="purchase_value" optional="hide" sum="Valeur totale"/>
                <field name="warranty_date"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'assigned'" decoration-warning="state == 'maintenance'" decoration-danger="state == 'retired'"/>
            </list>
        </field>
    </record>

    <record id="view_it_equipement_search" model="ir.ui.view">
        <field name="name">it.equipement.search</field>
        <field name="model">it.equipement</field>
        <field name="arch" type="xml">
            <search string="Recherche Équipements">
                <field name="name" string="Désignation / Numéro de série" filter_domain="['|', ('name', 'ilike', self), ('serial_number', 'ilike', self)]"/>
                <field name="serial_number"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <filter name="state_draft" string="Brouillon" domain="[('state', '=', 'draft')]"/>
                <filter name="state_assigned" string="Affecté" domain="[('state', '=', 'assigned')]"/>
                <filter name="state_maintenance" string="En maintenance" domain="[('state', '=', 'maintenance')]"/>
                <filter name="state_retired" string="Retiré" domain="[('state', '=', 'retired')]"/>
                <group expand="0" string="Regrouper par">
                    <filter string="Catégorie" name="group_by_category" context="{'group_by': 'category_id'}"/>
                    <filter string="Site / Localisation" name="group_by_location" context="{'group_by': 'location_id'}"/>
                    <filter string="Statut" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Département" name="group_by_department" context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_it_equipement_kanban" model="ir.ui.view">
        <field name="name">it.equipement.kanban</field>
        <field name="model">it.equipement</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="serial_number"/>
                <field name="category_id"/>
                <field name="employee_id"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>S/N: <field name="serial_number"/></div>
                                <div>Catégorie: <field name="category_id"/></div>
                                <div t-if="record.employee_id.raw_value">Utilisateur: <field name="employee_id"/></div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="state" widget="label_selection" options="{'classes': {'draft': 'info', 'assigned': 'success', 'maintenance': 'warning', 'retired': 'danger'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_it_equipement_form" model="ir.ui.view">
        <field name="name">it.equipement.form</field>
        <field name="model">it.equipement</field>
        <field name="arch" type="xml">
            <form string="Équipement informatique">
                <header>
                    <button name="%(action_it_reassign_wizard)d" string="Réaffecter / Assigner" type="action" class="btn-primary" invisible="state == 'retired'"/>
                    <button name="action_maintenance" string="Mettre en maintenance" type="object" class="btn-warning" invisible="state in ('maintenance', 'retired')"/>
                    <button name="action_assign" string="Remettre en service" type="object" class="btn-success" invisible="state != 'maintenance'"/>
                    <button name="action_retire" string="Mettre au rebut / Retirer" type="object" class="btn-danger" invisible="state == 'retired'" confirm="Êtes-vous sûr de vouloir retirer cet équipement définitivement ?"/>
                    <button name="action_draft" string="Remettre en brouillon" type="object" class="btn-secondary" invisible="state != 'retired'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,assigned,maintenance,retired"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Ex: Ordinateur Dell G15"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Informations Générales">
                            <field name="serial_number"/>
                            <field name="category_id" options="{'no_open': False, 'no_create': False}"/>
                            <field name="location_id" options="{'no_open': False, 'no_create': False}"/>
                        </group>
                        <group string="Affectation Actuelle">
                            <field name="employee_id"/>
                            <field name="department_id"/>
                        </group>
                        <group string="Intégration">
                            <field name="product_id" options="{'no_create': True}"/>
                            <field name="purchase_order_id" options="{'no_create': True}"/>
                            <field name="invoice_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group>
                        <group string="Achat et Garantie">
                            <field name="purchase_value"/>
                            <field name="purchase_date"/>
                            <field name="warranty_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description technique" name="description">
                            <field name="description" placeholder="Spécifications techniques détaillées (Processeur, RAM, Stockage, OS...)"/>
                        </page>
                        <page string="Historique d'affectations" name="affectations">
                            <field name="affectation_ids" readonly="1">
                                <list>
                                    <field name="employee_id"/>
                                    <field name="department_id"/>
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                    <field name="reason"/>
                                    <field name="state" widget="badge" decoration-success="state == 'active'" decoration-muted="state == 'completed'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Interventions de Maintenance" name="interventions">
                            <field name="intervention_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="technician_id"/>
                                    <field name="type"/>
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                    <field name="duration" widget="float_time"/>
                                    <field name="cost" sum="Coût total des pannes"/>
                                </list>
                            </field>
                        </page>
                        <page string="Contrats liés" name="contrats">
                            <field name="contrat_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_it_equipement" model="ir.actions.act_window">
        <field name="name">Équipements</field>
        <field name="res_model">it.equipement</field>
        <field name="view_mode">list,form,kanban,search</field>
    </record>
</odoo>

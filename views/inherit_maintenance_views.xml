<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_maintenance_request_form_inherit_it_parc" model="ir.ui.view">
        <field name="name">maintenance.request.form.inherit.it.parc</field>
        <field name="model">maintenance.request</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_request_view_form"/>
        <field name="arch" type="xml">
            <div class="oe_title" position="before">
                <div class="oe_button_box" name="button_box">
                    <button class="oe_stat_button"
                            name="action_open_it_intervention"
                            type="object"
                            icon="fa-wrench"
                            invisible="it_intervention_id == False">
                        <div class="o_stat_info">
                            <span class="o_stat_text">Intervention IT</span>
                        </div>
                    </button>
                </div>
            </div>
            <field name="category_id" position="after">
                <field name="it_intervention_id" readonly="1" invisible="it_intervention_id == False"/>
            </field>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inventory Report Wizard Form View -->
    <record id="view_it_inventory_report_wizard_form" model="ir.ui.view">
        <field name="name">it.inventory.report.wizard.form</field>
        <field name="model">it.inventory.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Imprimer le rapport d'inventaire complet">
                <sheet>
                    <group>
                        <field name="category_id" options="{'no_create': True}"/>
                        <field name="department_id" options="{'no_create': True}"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_print_pdf" string="Imprimer le PDF" type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_it_inventory_report_wizard" model="ir.actions.act_window">
        <field name="name">Rapport d'inventaire filtrable</field>
        <field name="res_model">it.inventory.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Maintenance Report Wizard Form View -->
    <record id="view_it_maintenance_report_wizard_form" model="ir.ui.view">
        <field name="name">it.maintenance.report.wizard.form</field>
        <field name="model">it.maintenance.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Imprimer l'historique des maintenances par période">
                <sheet>
                    <group>
                        <field name="date_start"/>
                        <field name="date_end"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_print_pdf" string="Imprimer le PDF" type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_it_maintenance_report_wizard" model="ir.actions.act_window">
        <field name="name">Historique des interventions par période</field>
        <field name="res_model">it.maintenance.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
